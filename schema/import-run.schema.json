{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pip/import-run.schema.json",
  "title": "PIP Import Run v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "run_id", "status", "started_at", "finished_at", "adapters"],
  "properties": {
    "schema_version": {"const": "1.0"},
    "run_id": {"type": "string", "pattern": "^run-[0-9]{8}T[0-9]{12}Z$"},
    "status": {"enum": ["succeeded", "failed"]},
    "started_at": {"type": "string", "format": "date-time"},
    "finished_at": {"type": "string", "format": "date-time"},
    "idempotency_key": {"type": "string", "pattern": "^[a-f0-9]{64}$"},
    "same_inputs_as_run_id": {"type": ["string", "null"]},
    "adapters": {"type": "array", "items": {"type": "object"}},
    "layout_statuses": {"type": "object", "additionalProperties": {"enum": ["new", "unchanged", "changed"]}},
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapters", "properties", "issues"],
      "properties": {
        "adapters": {"type": "integer", "minimum": 0},
        "properties": {"type": "integer", "minimum": 0},
        "issues": {"type": "integer", "minimum": 0}
      }
    },
    "error": {
      "type": "object",
      "required": ["type", "message"],
      "properties": {
        "type": {"type": "string"},
        "message": {"type": "string"}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "succeeded"}}},
      "then": {"required": ["idempotency_key", "same_inputs_as_run_id", "layout_statuses", "totals"]}
    },
    {
      "if": {"properties": {"status": {"const": "failed"}}},
      "then": {"required": ["error"]}
    }
  ]
}
