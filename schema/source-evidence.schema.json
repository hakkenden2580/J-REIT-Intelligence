{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/pip/source-evidence.schema.json",
  "title": "PIP Source Evidence v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metric_code",
    "value",
    "unit",
    "observed_at",
    "source_document_id",
    "retrieved_at",
    "locator",
    "extraction",
    "review"
  ],
  "properties": {
    "metric_code": {"type": "string", "minLength": 1},
    "value": {"type": "number"},
    "unit": {"type": "string", "minLength": 1},
    "observed_at": {"type": ["string", "null"], "format": "date"},
    "source_document_id": {"type": "string", "pattern": "^doc-[a-f0-9]{20}$"},
    "retrieved_at": {"type": "string", "format": "date-time"},
    "locator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "page", "sheet", "cell", "cell_range", "bbox"],
      "properties": {
        "type": {"enum": ["excel_cell", "pdf_bbox", "xbrl_fact", "html_selector"]},
        "page": {"type": ["integer", "null"], "minimum": 1},
        "sheet": {"type": ["string", "null"]},
        "cell": {"type": ["string", "null"]},
        "cell_range": {"type": ["string", "null"]},
        "bbox": {
          "oneOf": [
            {"type": "null"},
            {"type": "array", "items": {"type": "number"}, "minItems": 4, "maxItems": 4}
          ]
        }
      }
    },
    "extraction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["parser", "parser_version", "method", "confidence"],
      "properties": {
        "parser": {"type": "string", "minLength": 1},
        "parser_version": {"type": "string", "minLength": 1},
        "method": {"type": "string", "minLength": 1},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "reviewed_by", "reviewed_at"],
      "properties": {
        "status": {"enum": ["pending", "approved", "rejected", "not_required"]},
        "reviewed_by": {"type": ["string", "null"]},
        "reviewed_at": {"type": ["string", "null"], "format": "date-time"}
      }
    }
  }
}
